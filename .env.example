############################################
# LiNa AI System — Environment Configuration
############################################

############################################
# SYSTEM
############################################

APP_NAME=LiNa
APP_ENV=development
APP_PORT=3000
LOG_LEVEL=info

############################################
# TELEGRAM
############################################

TELEGRAM_BOT_TOKEN=

# lista separada por vírgula
TELEGRAM_ALLOWED_USER_IDS=

TELEGRAM_POLLING_INTERVAL=1000

############################################
# SUPABASE
############################################

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

############################################
# MULTI LLM CONFIGURATION
############################################

DEFAULT_LLM_PROVIDER=gemini

LLM_FALLBACK_ORDER=gemini,openai,deepseek,openrouter,anthropic,groq,zai,ollama

############################################
# GEMINI
############################################

GEMINI_API_KEYS=

GEMINI_MODEL=gemini-1.5-pro

############################################
# OPENAI
############################################

OPENAI_API_KEYS=

OPENAI_MODEL=gpt-4o

############################################
# DEEPSEEK
############################################

DEEPSEEK_API_KEYS=

DEEPSEEK_MODEL=deepseek-chat

############################################
# OPENROUTER
############################################

OPENROUTER_API_KEYS=

OPENROUTER_MODEL=anthropic/claude-3-opus

############################################
# ANTHROPIC
############################################

ANTHROPIC_API_KEYS=

ANTHROPIC_MODEL=claude-3-opus

############################################
# GROQ
############################################

GROQ_API_KEYS=

GROQ_MODEL=llama-3.3-70b-versatile

############################################
# Z.AI
############################################

ZAI_API_KEYS=

ZAI_BASE_URL=https://api.z.ai/api/paas/v4

ZAI_MODEL=glm-5

############################################
# OLLAMA LOCAL
############################################

OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_MODEL=llama3

############################################
# SEARCH APIs
############################################

BRAVE_SEARCH_API_KEYS=

TAVILY_API_KEYS=

SERPAPI_KEYS=

FIRECRAWL_API_KEYS=

JINA_API_KEYS=

############################################
# AGENT LOOP LIMITS
############################################

MAX_ITERATIONS=5

MAX_EXECUTION_TIME_MS=60000

MAX_TOOL_CALLS_PER_TOOL=3

############################################
# COST LIMITS
############################################

MAX_COST_PER_TASK=0.25

MAX_TOKENS_PER_TASK=20000

############################################
# SKILLS
############################################

SKILLS_DIRECTORY=./.agents/skills

ENABLE_SKILLS=true

############################################
# AGENTS
############################################

ENABLE_RESEARCH_AGENT=true
ENABLE_AUTOMATION_AGENT=true
ENABLE_CODING_AGENT=true
ENABLE_FINANCE_AGENT=true

############################################
# DASHBOARD
############################################

ENABLE_DASHBOARD=true

DASHBOARD_PORT=3001

ENABLE_KANBAN=true

ENABLE_REALTIME_UPDATES=true

############################################
# LOGGING
############################################

ENABLE_LOGS=true

LOG_RETENTION_DAYS=30

############################################
# FILESYSTEM SAFETY
############################################

WORKSPACE_DIR=./workspace

TEMP_DIR=./tmp

FORBIDDEN_PATHS=/etc,/root,/home

############################################
# AUDIO / VOICE (future)
############################################

ENABLE_AUDIO_RESPONSES=false

TTS_PROVIDER=

STT_PROVIDER=
